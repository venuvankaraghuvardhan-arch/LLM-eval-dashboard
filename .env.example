# LLM API Keys (leave blank to use MOCK_MODE)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
MISTRAL_API_KEY=your-mistral-key-here

# App Settings
DATABASE_URL=sqlite+aiosqlite:///./eval_data.db
MOCK_MODE=true
LOG_LEVEL=INFO
APP_ENV=development

# Prometheus
PROMETHEUS_PORT=8000
